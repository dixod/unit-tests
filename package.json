{
  "name": "practice-unit-tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "mocha --require @babel/register \"test/**/*.test.js\" --reporter mochawesome --reporter-option reportDir=mochawesome-report,reportFilename=index,quiet=true",
    "coverage": "c8 --all --include=utils/**/*.js --reporter=text --reporter=html mocha --require @babel/register \"test/**/*.test.js\"",
    "eslint": "eslint .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/register": "^7.28.6",
    "@eslint/js": "^9.39.4",
    "c8": "^10.1.3",
    "chai": "^4.5.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "mocha": "^11.7.5",
    "mochawesome": "^7.1.4"
  }
}
